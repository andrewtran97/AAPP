{
  "schema_version": "aapp.firewall_policy.v1",
  "default_decision": "DENY",
  "rules": [
    {
      "id": "allow-read-status",
      "match": {"tool_name": "read_status"},
      "decision": "ALLOW",
      "reason": "read_only_tool_allowed"
    },
    {
      "id": "deny-delete-db",
      "match": {"tool_name": "delete_database"},
      "decision": "DENY",
      "reason": "destructive_database_operation"
    },
    {
      "id": "approval-refund",
      "match": {"tool_name": "refund_payment"},
      "decision": "REQUIRE_APPROVAL",
      "reason": "payment_refund_requires_approval"
    },
    {
      "id": "deny-blocked-prefix",
      "match": {"tool_name_prefix": "blocked_"},
      "decision": "DENY",
      "reason": "blocked_tool_prefix"
    }
  ]
}
